<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Export compliance: Subnix uses only standard, OS-provided encryption
	     (HTTPS/TLS via URLSession + Network.framework, and Apple's Security
	     framework). No proprietary crypto → exempt. Declaring this here stops
	     App Store Connect asking about encryption on every submission. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Bonjour service types Subnix is allowed to browse. This MUST stay in
	     sync with BonjourScanner.defaultServiceTypes — iOS (and macOS 15+)
	     return nothing for any type not declared here. Array-typed, so it lives
	     in this partial plist rather than an INFOPLIST_KEY build setting; the
	     rest of Info.plist is still generated and merged in at build time. -->
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
		<string>_https._tcp</string>
		<string>_ssh._tcp</string>
		<string>_smb._tcp</string>
		<string>_afpovertcp._tcp</string>
		<string>_ipp._tcp</string>
		<string>_printer._tcp</string>
		<string>_airplay._tcp</string>
		<string>_raop._tcp</string>
		<string>_googlecast._tcp</string>
		<string>_homekit._tcp</string>
		<string>_hap._tcp</string>
		<string>_rfb._tcp</string>
		<string>_device-info._tcp</string>
	</array>
</dict>
</plist>
